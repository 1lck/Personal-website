---
import WorkCard from "@/components/cards/WorkCard.astro";
import SectionHeader from "@/components/elements/SectionHeader.astro";
import Button from "@/components/ui/Button.astro";
import { apiClient, type Project as ProjectModel } from "@/lib/apiClient";

interface Props {
  title?: string;
  description?: string;
  showAll?: boolean;
  limit?: number;
}

const {
  title = "精选作品",
  description = "这些作品覆盖课堂实验、实验室协作与个人兴趣，展示我如何把 Java 与界面实现结合。",
  showAll = false,
  limit
} = Astro.props as Props;

let projects: ProjectModel[] = [];
let projectLoadError: string | null = null;

try {
  projects = await apiClient.fetchProjects();
} catch (error) {
  projectLoadError = error instanceof Error ? error.message : "无法加载项目数据";
}

const totalProjects = projects.length;
let visibleProjects = projects;

if (typeof limit === "number") {
  visibleProjects = projects.slice(0, limit);
} else if (!showAll) {
  visibleProjects = projects.slice(0, 6);
}

const featuredProjects = visibleProjects.slice(0, 3);
const gridProjects = visibleProjects.slice(3);

const shouldShowViewAll = typeof limit === "number"
  ? limit < totalProjects
  : !showAll && totalProjects > 6;

const fallbackImage = "/assets/home/gradientshub.jpg";
---

<section class="py-16 md:py-16 md:pb-12">
  <div class="site-container space-y-8 md:space-y-8">
    <SectionHeader title={title} description={description} />

    {projectLoadError && (
      <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600 dark:border-red-900/40 dark:bg-red-900/20">
        {projectLoadError}
      </div>
    )}

    {!projectLoadError && totalProjects === 0 && (
      <div class="rounded-xl border border-dashed border-neutral-200 px-4 py-6 text-center text-sm text-neutral-500 dark:border-neutral-700 dark:text-neutral-300">
        暂无作品，请在后台添加首批项目。
      </div>
    )}

    {!projectLoadError && totalProjects > 0 && (
      <>
        {featuredProjects.length > 0 && (
          <div
            class="space-y-8 md:space-y-10"
            data-aos-delay="750"
            data-aos="fade-up-sm"
            data-aos-duration="1000"
            data-aos-once="true"
          >
            {featuredProjects.map((project, index) => (
              <WorkCard
                name={project.title}
                description={project.description}
                image={project.coverImageUrl || fallbackImage}
                url={project.link}
                tags={project.tags}
                video={project.videoUrl}
                layout="featured"
                index={index}
              />
            ))}
          </div>
        )}

        {gridProjects.length > 0 && (
          <div
            class="grid gap-6 md:gap-8 md:grid-cols-2"
            data-aos-delay="150"
            data-aos="fade-up-sm"
            data-aos-duration="1000"
            data-aos-once="true"
          >
            {gridProjects.map((project, index) => (
              <WorkCard
                name={project.title}
                description={project.description}
                image={project.coverImageUrl || fallbackImage}
                url={project.link}
                tags={project.tags}
                video={project.videoUrl}
                layout="grid"
                index={index}
              />
            ))}
          </div>
        )}

        {shouldShowViewAll && (
          <div class="flex items-center justify-center pt-4">
            <Button url="/works" className="w-full max-w-60">
              查看全部作品
            </Button>
          </div>
        )}
      </>
    )}
  </div>
</section>
