---
import Layout from "@/layouts/Layout.astro";

export const prerender = false;

const apiBase = import.meta.env.PUBLIC_API_BASE_URL || "http://localhost:8080";
---

<Layout title="后台管理">
  <section class="site-container mx-auto my-12 space-y-6">
    <div class="rounded-2xl border border-neutral-200/80 bg-white p-6 shadow-sm dark:border-neutral-800 dark:bg-neutral-900/60">
      <h1 class="text-2xl font-brand text-neutral-900 dark:text-white mb-4">后台管理面板</h1>
      <p class="text-sm text-neutral-600 dark:text-neutral-300">
        接口基地址：<code class="rounded bg-neutral-100 px-2 py-1 text-xs dark:bg-neutral-800">{apiBase}</code>
      </p>
      <p class="text-sm text-neutral-600 dark:text-neutral-400">
        所有写操作都需要在下方输入后台 Token。由于仅自用，后台未做复杂权限控制，请自行妥善保管 Token。
      </p>
      <div class="mt-4 flex flex-col gap-2 md:flex-row md:items-center">
        <label class="text-sm font-medium text-neutral-700 dark:text-neutral-200" for="admin-token">后台 Token</label>
        <input
          id="admin-token"
          type="password"
          placeholder="在 application.yml 中设置的 CONTENT_ADMIN_TOKEN"
          class="flex-1 rounded-lg border border-neutral-200 px-3 py-2 text-sm text-neutral-800 focus:border-primary focus:outline-none dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-100"
        />
      </div>
      <div id="admin-status" class="mt-4 text-sm text-neutral-500 dark:text-neutral-300"></div>
    </div>

    <!-- Quick Navigation -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      <a href="/admin/projects" class="group admin-nav-card">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="font-semibold text-neutral-900 dark:text-white mb-1">项目管理</h3>
            <p class="text-xs text-neutral-600 dark:text-neutral-400">管理首页项目展示</p>
          </div>
          <svg class="w-5 h-5 text-primary group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </a>
      <a href="/admin/posts" class="group admin-nav-card">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="font-semibold text-neutral-900 dark:text-white mb-1">文章管理</h3>
            <p class="text-xs text-neutral-600 dark:text-neutral-400">管理博客文章内容</p>
          </div>
          <svg class="w-5 h-5 text-primary group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </a>
      <a href="/admin/works" class="group admin-nav-card">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="font-semibold text-neutral-900 dark:text-white mb-1">作品管理</h3>
            <p class="text-xs text-neutral-600 dark:text-neutral-400">管理作品集展示</p>
          </div>
          <svg class="w-5 h-5 text-primary group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </div>
      </a>
    </div>

    <div class="grid gap-6">
      <article class="admin-card">
        <header>
          <h2>个人信息</h2>
          <p>更新首页展示的姓名、简介、联系信息以及按钮文案。</p>
        </header>
        <form id="profile-form" class="admin-form">
          <div class="form-grid">
            <label>
              姓名
              <input name="fullName" type="text" required />
            </label>
            <label>
              标题
              <input name="headline" type="text" />
            </label>
            <label class="col-span-2">
              个人简介
              <textarea name="bio" rows="3"></textarea>
            </label>
            <label>
              邮箱
              <input name="email" type="email" />
            </label>
            <label>
              电话
              <input name="phone" type="text" />
            </label>
            <label>
              微信
              <input name="wechat" type="text" />
            </label>
            <label>
              所在地
              <input name="location" type="text" />
            </label>
            <label>
              职责 / 身份
              <input name="jobTitle" type="text" />
            </label>
            <label class="col-span-2">
              Hero 图
              <input type="hidden" name="heroImagePath" />
              <input
                type="file"
                accept="image/*"
                data-upload-target="heroImagePath"
                data-upload-category="profile-hero"
                data-upload-status="#profile-hero-status"
              />
              <p id="profile-hero-status" class="upload-status">尚未上传</p>
            </label>
            <label class="col-span-2">
              简历文件
              <input type="hidden" name="resumePath" />
              <input
                type="file"
                accept=".pdf,.doc,.docx"
                data-upload-target="resumePath"
                data-upload-category="profile-resume"
                data-upload-status="#profile-resume-status"
              />
              <p id="profile-resume-status" class="upload-status">尚未上传</p>
            </label>
            <label>
              主按钮文案
              <input name="primaryCtaLabel" type="text" />
            </label>
            <label>
              主按钮链接
              <input name="primaryCtaLink" type="url" />
            </label>
            <label>
              次按钮文案
              <input name="secondaryCtaLabel" type="text" />
            </label>
            <label>
              次按钮链接
              <input name="secondaryCtaLink" type="url" />
            </label>
            <label class="col-span-2">
              社交链接（JSON，例如 <code>&#123;"github":"https://github.com/1lck"&#125;</code>）
              <textarea name="socialLinks" rows="2"></textarea>
            </label>
          </div>
          <button type="submit" class="admin-button">保存个人信息</button>
        </form>
      </article>

      <article class="admin-card">
        <header>
          <h2>文件上传</h2>
          <p>文件将直接写入服务器磁盘 storage 目录，返回可供项目或文章引用的路径。</p>
        </header>
        <form id="upload-form" class="admin-form" enctype="multipart/form-data">
          <div class="form-grid">
            <label>
              分类（可选）
              <input name="category" type="text" placeholder="projects / posts / profile / works" />
            </label>
            <label class="col-span-2">
              选择文件
              <input name="file" type="file" required />
            </label>
          </div>
          <button type="submit" class="admin-button">上传文件</button>
        </form>
        <div id="upload-result" class="mt-4 text-xs text-neutral-600 dark:text-neutral-300"></div>
      </article>
    </div>
  </section>

  <style>
    .admin-nav-card {
      display: block;
      border-radius: 1rem;
      border: 1px solid rgba(15, 23, 42, 0.08);
      background: rgba(255, 255, 255, 0.95);
      padding: 1.25rem;
      box-shadow: 0 4px 12px rgba(15, 23, 42, 0.05);
      transition: all 0.3s ease;
    }

    .admin-nav-card:not(.opacity-50):hover {
      border-color: rgba(99, 102, 241, 0.3);
      box-shadow: 0 8px 24px rgba(99, 102, 241, 0.15);
      transform: translateY(-2px);
    }

    :global(.dark) .admin-nav-card {
      border-color: rgba(255, 255, 255, 0.08);
      background: rgba(15, 23, 42, 0.8);
    }

    :global(.dark) .admin-nav-card:not(.opacity-50):hover {
      border-color: rgba(99, 102, 241, 0.4);
      box-shadow: 0 8px 24px rgba(99, 102, 241, 0.2);
    }

    .admin-card {
      border-radius: 1.25rem;
      border: 1px solid rgba(15, 23, 42, 0.08);
      background: rgba(255, 255, 255, 0.95);
      padding: 1.75rem;
      box-shadow: 0 20px 40px rgba(15, 23, 42, 0.08);
    }

    :global(.dark) .admin-card {
      border-color: rgba(255, 255, 255, 0.08);
      background: rgba(15, 23, 42, 0.8);
    }

    .admin-card header h2 {
      font-size: 1.375rem;
      font-weight: 600;
      color: rgb(15 23 42);
    }

    :global(.dark) .admin-card header h2 {
      color: rgb(226 232 240);
    }

    .admin-card header p {
      font-size: 0.875rem;
      color: rgb(100 116 139);
      margin-top: 0.25rem;
    }

    .admin-form {
      margin-top: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .form-grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }

    .form-grid label {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      font-size: 0.9rem;
      color: rgb(15 23 42);
    }

    :global(.dark) .form-grid label {
      color: rgb(226 232 240);
    }

    .form-grid input,
    .form-grid textarea {
      border-radius: 0.75rem;
      border: 1px solid rgba(15, 23, 42, 0.15);
      padding: 0.65rem 0.85rem;
      font-size: 0.9rem;
      background: rgba(255, 255, 255, 0.95);
      color: rgb(15 23 42);
    }

    :global(.dark) .form-grid input,
    :global(.dark) .form-grid textarea {
      border-color: rgba(255, 255, 255, 0.15);
      background: rgba(15, 23, 42, 0.7);
      color: rgb(226 232 240);
    }

    .admin-button {
      align-self: flex-start;
      border-radius: 999px;
      padding: 0.65rem 1.5rem;
      font-size: 0.9rem;
      font-weight: 600;
      color: white;
      background: linear-gradient(120deg, #6366f1, #ec4899);
      border: none;
      cursor: pointer;
      transition: all 0.2s;
    }

    .admin-button:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);
    }

    .admin-secondary {
      border-radius: 999px;
      padding: 0.65rem 1.5rem;
      font-size: 0.85rem;
      border: 1px solid rgba(15, 23, 42, 0.15);
      background: transparent;
    }

    .admin-list {
      display: block;
    }

    .checkbox-label {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 500;
    }

    .upload-status {
      font-size: 0.75rem;
      color: rgb(100 116 139);
      margin-top: 0.25rem;
    }

    .col-span-2 {
      grid-column: span 2;
    }
  </style>

  <script>
    import initAdminDashboard from "@/scripts/admin-dashboard";
    initAdminDashboard();
  </script>
</Layout>
          </div>
          <div class="flex flex-wrap gap-3">
            <button type="submit" class="admin-button">保存项目</button>
            <button type="button" data-reset-project class="admin-secondary">重置表单</button>
          </div>
        </form>
      </article>

      <article class="admin-card">
        <header>
          <h2>博客文章</h2>
          <p>支持 Markdown 内容，后台自动转换为 HTML 并生成 TOC。</p>
        </header>
        <div id="posts-list" class="admin-list"></div>
        <form id="post-form" class="admin-form">
          <input type="hidden" name="id" />
          <div class="form-grid">
            <label>
              标题
              <input name="title" type="text" required />
            </label>
            <label>
              Slug（URL）
              <input name="slug" type="text" required />
            </label>
            <label class="col-span-2">
              摘要
              <textarea name="summary" rows="2"></textarea>
            </label>
            <label class="col-span-2">
              Markdown 正文
              <textarea name="content" rows="6" placeholder="支持标准 Markdown 语法" class="sr-only" required></textarea>
              <input
                type="file"
                accept=".md,.markdown,.mdx,.txt"
                data-markdown-target="content"
                data-upload-status="#post-markdown-status"
              />
              <p id="post-markdown-status" class="upload-status">尚未选择 Markdown 文件</p>
            </label>
            <label>
              封面
              <input type="hidden" name="coverImagePath" />
              <input
                type="file"
                accept="image/*"
                data-upload-target="coverImagePath"
                data-upload-category="posts-cover"
                data-upload-status="#post-cover-status"
              />
              <p id="post-cover-status" class="upload-status">尚未上传</p>
            </label>
            <label>
              发布时间
              <input name="publishDate" type="datetime-local" />
            </label>
            <label>
              标签（逗号分隔）
              <input name="tags" type="text" />
            </label>
            <label class="checkbox-label">
              <input name="featured" type="checkbox" />
              设为精选
            </label>
            <label class="checkbox-label">
              <input name="published" type="checkbox" checked />
              发布
            </label>
          </div>
          <div class="flex flex-wrap gap-3">
            <button type="submit" class="admin-button">保存文章</button>
            <button type="button" data-reset-post class="admin-secondary">重置表单</button>
          </div>
        </form>
      </article>

      <article class="admin-card">
        <header>
          <h2>作品管理</h2>
          <p>管理 My Works 页面展示的作品集。</p>
        </header>
        <div id="works-list"></div>
        <form id="work-form" class="admin-form">
          <input name="id" type="hidden" />
          <div class="form-grid">
            <label>
              作品名称
              <input name="name" type="text" required />
            </label>
            <label>
              链接地址
              <input name="url" type="text" required />
            </label>
            <label class="col-span-2">
              描述
              <textarea name="description" rows="2"></textarea>
            </label>
            <label>
              封面图片
              <input type="hidden" name="imagePath" />
              <input
                type="file"
                accept="image/*"
                data-upload-target="imagePath"
                data-upload-category="works-image"
                data-upload-status="#work-image-status"
              />
              <p id="work-image-status" class="upload-status">尚未上传</p>
            </label>
            <label>
              视频（可选）
              <input type="hidden" name="videoPath" />
              <input
                type="file"
                accept="video/*"
                data-upload-target="videoPath"
                data-upload-category="works-video"
                data-upload-status="#work-video-status"
              />
              <p id="work-video-status" class="upload-status">尚未上传</p>
            </label>
            <label>
              标签（逗号分隔）
              <input name="tags" type="text" />
            </label>
            <label>
              排序
              <input name="sortOrder" type="number" value="0" />
            </label>
            <label class="checkbox-label">
              <input name="isShow" type="checkbox" checked />
              显示
            </label>
          </div>
          <div class="flex flex-wrap gap-3">
            <button type="submit" class="admin-button">保存作品</button>
            <button type="button" data-reset-work class="admin-secondary">重置表单</button>
          </div>
        </form>
      </article>

      <article class="admin-card">
        <header>
          <h2>文件上传</h2>
          <p>文件将直接写入服务器磁盘 storage 目录，返回可供项目或文章引用的路径。</p>
        </header>
        <form id="upload-form" class="admin-form" enctype="multipart/form-data">
          <div class="form-grid">
            <label>
              分类（可选）
              <input name="category" type="text" placeholder="projects / posts / profile" />
            </label>
            <label class="col-span-2">
              选择文件
              <input name="file" type="file" required />
            </label>
          </div>
          <button type="submit" class="admin-button">上传文件</button>
        </form>
        <div id="upload-result" class="mt-4 text-xs text-neutral-600 dark:text-neutral-300"></div>
      </article>
    </div>
  </section>

  <style>
    .admin-nav-card {
      display: block;
      border-radius: 1rem;
      border: 1px solid rgba(15, 23, 42, 0.08);
      background: rgba(255, 255, 255, 0.95);
      padding: 1.25rem;
      box-shadow: 0 4px 12px rgba(15, 23, 42, 0.05);
      transition: all 0.3s ease;
    }

    .admin-nav-card:not(.opacity-50):hover {
      border-color: rgba(99, 102, 241, 0.3);
      box-shadow: 0 8px 24px rgba(99, 102, 241, 0.15);
      transform: translateY(-2px);
    }

    :global(.dark) .admin-nav-card {
      border-color: rgba(255, 255, 255, 0.08);
      background: rgba(15, 23, 42, 0.8);
    }

    :global(.dark) .admin-nav-card:not(.opacity-50):hover {
      border-color: rgba(99, 102, 241, 0.4);
      box-shadow: 0 8px 24px rgba(99, 102, 241, 0.2);
    }

    .admin-card {
      border-radius: 1.25rem;
      border: 1px solid rgba(15, 23, 42, 0.08);
      background: rgba(255, 255, 255, 0.95);
      padding: 1.75rem;
      box-shadow: 0 20px 40px rgba(15, 23, 42, 0.08);
    }

    :global(.dark) .admin-card {
      border-color: rgba(255, 255, 255, 0.08);
      background: rgba(15, 23, 42, 0.8);
    }

    .admin-card header h2 {
      font-size: 1.375rem;
      font-weight: 600;
      color: rgb(15 23 42);
    }

    :global(.dark) .admin-card header h2 {
      color: rgb(226 232 240);
    }

    .admin-card header p {
      font-size: 0.875rem;
      color: rgb(100 116 139);
      margin-top: 0.25rem;
    }

    .admin-form {
      margin-top: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .form-grid {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    }

    .form-grid label {
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
      font-size: 0.9rem;
      color: rgb(15 23 42);
    }

    :global(.dark) .form-grid label {
      color: rgb(226 232 240);
    }

    .form-grid input,
    .form-grid textarea {
      border-radius: 0.75rem;
      border: 1px solid rgba(15, 23, 42, 0.15);
      padding: 0.65rem 0.85rem;
      font-size: 0.9rem;
      background: rgba(255, 255, 255, 0.95);
      color: rgb(15 23 42);
    }

    :global(.dark) .form-grid input,
    :global(.dark) .form-grid textarea {
      border-color: rgba(255, 255, 255, 0.15);
      background: rgba(15, 23, 42, 0.7);
      color: rgb(226 232 240);
    }

    .admin-button {
      align-self: flex-start;
      border-radius: 999px;
      padding: 0.65rem 1.5rem;
      font-size: 0.9rem;
      font-weight: 600;
      color: white;
      background: linear-gradient(120deg, #6366f1, #ec4899);
      border: none;
    }

    .admin-secondary {
      border-radius: 999px;
      padding: 0.6rem 1.4rem;
      font-size: 0.85rem;
      border: 1px solid rgba(15, 23, 42, 0.15);
      background: transparent;
    }

    .admin-list {
      display: block;
    }

    .admin-table-wrapper {
      border-radius: 0.75rem;
      border: 1px solid rgba(15, 23, 42, 0.08);
      overflow-x: auto;
      max-height: 400px;
      overflow-y: auto;
    }

    .admin-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
    }

    .admin-table th,
    .admin-table td {
      padding: 0.5rem 0.75rem;
      text-align: left;
      border-bottom: 1px solid rgba(15, 23, 42, 0.06);
    }

    .admin-table th {
      background: rgba(99, 102, 241, 0.08);
      font-weight: 600;
      color: rgb(45 55 72);
      position: sticky;
      top: 0;
      z-index: 10;
      font-size: 0.8rem;
    }

    .admin-table tbody tr:hover {
      background: rgba(99, 102, 241, 0.03);
    }

    .admin-table-actions {
      display: flex;
      gap: 0.35rem;
      flex-wrap: nowrap;
    }

    .admin-table-actions button {
      border-radius: 0.375rem;
      border: 1px solid rgba(99, 102, 241, 0.25);
      background: white;
      color: rgb(99 102 241);
      font-size: 0.75rem;
      padding: 0.25rem 0.6rem;
      white-space: nowrap;
      transition: all 0.2s;
    }

    .admin-table-actions button:hover {
      background: rgba(99, 102, 241, 0.1);
      border-color: rgba(99, 102, 241, 0.4);
    }

    :global(.dark) .admin-table-wrapper {
      border-color: rgba(255, 255, 255, 0.12);
    }

    :global(.dark) .admin-table th {
      background: rgba(99, 102, 241, 0.15);
      color: rgb(226 232 240);
    }

    :global(.dark) .admin-table td {
      border-color: rgba(255, 255, 255, 0.08);
      color: rgb(226 232 240);
    }

    :global(.dark) .admin-table-actions button {
      background: rgba(15, 23, 42, 0.6);
      color: rgb(226 232 240);
      border-color: rgba(99, 102, 241, 0.3);
    }

    :global(.dark) .admin-table-actions button:hover {
      background: rgba(99, 102, 241, 0.2);
      border-color: rgba(99, 102, 241, 0.5);
    }

    :global(.dark) .admin-table tbody tr:hover {
      background: rgba(99, 102, 241, 0.08);
    }

    .checkbox-label {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 500;
    }

    .upload-status {
      margin-top: 0.35rem;
      font-size: 0.8rem;
      color: rgb(99 102 241);
    }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  </style>

  <script type="module" is:inline>
    import initAdminDashboard from "/src/scripts/admin-dashboard.ts";
    initAdminDashboard();
  </script>
</Layout>
